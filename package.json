{
  "name": "cycle-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server/index.js",
    "start": "node server/index.js",
    "server": "node server/index.js",
    "products:clean": "node server/clean-products.js",
