PORT=3001

# Public URL of backend (needed for Telegram image links in production)
# Example: https://api.your-domain.com
PUBLIC_BASE_URL=http://localhost:3001

# Mini app URL (the URL that should open from Telegram)
# Example: https://your-domain.com
WEB_APP_URL=http://localhost:5173

# Telegram bot token from @BotFather
TG_BOT_TOKEN=

# Optional: comma-separated Telegram user IDs allowed to publish
# Example: 123456789,987654321
TG_ADMIN_IDS=

# Optional: protects POST /api/products (set same key in integrations)
API_KEY=

# Frontend -> backend (for Vite dev)
VITE_API_BASE_URL=http://localhost:3001
