PORT=3001

# Public URL of backend (needed for Telegram image links in production)
# Example: https://api.your-domain.com
PUBLIC_BASE_URL=http://localhost:3001

# Mini app URL (the URL that should open from Telegram)
# Example: https://your-domain.com
WEB_APP_URL=http://localhost:5173

# Telegram bot token from @BotFather
TG_BOT_TOKEN=

# Optional: comma-separated Telegram user IDs allowed to publish
# Example: 123456789,987654321
TG_ADMIN_IDS=

# Optional: public channel auto-sync (t.me/s/<channel>)
TG_CHANNEL_SYNC_ENABLED=true
TG_CHANNEL_USERNAME=cycle_showroom
TG_CHANNEL_SYNC_INTERVAL_MS=300000
TG_CHANNEL_SYNC_LIMIT=40
TG_CHANNEL_SYNC_MAX_PAGES=6
# Optional: if true, one sync run scans all available pages instead of max pages/limit.
TG_CHANNEL_SYNC_FULL=false
# Optional: cap for `npm run sync:channel:full` (empty = no manual cap).
TG_CHANNEL_SYNC_FULL_MAX_PAGES=
TG_CHANNEL_SYNC_TIMEOUT_MS=15000

# Optional: protects POST /api/products (set same key in integrations)
API_KEY=

# Frontend -> backend (for Vite dev)
VITE_API_BASE_URL=http://localhost:3001
